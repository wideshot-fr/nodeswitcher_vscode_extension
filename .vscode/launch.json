{
	"version": "0.2.0",
	"configurations": [
		

		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/nodeswitcher"
			],
			"outFiles": [
				"${workspaceFolder}/nodeswitcher/dist/**/*.js"
			],
			"preLaunchTask": "npm: compile - nodeswitcher"
		}
	]
}
